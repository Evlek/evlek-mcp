{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "app.evlek/mcp-server",
  "title": "Evlek — Northern Cyprus Property MCP Server",
  "description": "AI-native property MCP for Northern Cyprus (KKTC/TRNC): listings, prices, legal, market data.",
  "version": "1.5.0",
  "websiteUrl": "https://evlek.app/mcp",
  "repository": {
    "url": "https://github.com/Evlek/evlek-mcp",
    "source": "github",
    "id": "1233174805"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://evlek.app/api/mcp"
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "publisher": {
        "name": "Evlek",
        "url": "https://evlek.app",
        "email": "hello@evlek.app"
      },
      "license": "MIT",
      "licenseScope": "MIT covers this public repository's manifest, documentation, examples, and reference clients only. Hosted Evlek service, web/mobile apps, listing database, AI prompts, business logic, brand assets, name, logo, and trade dress are proprietary.",
      "homepage": "https://evlek.app",
      "documentation": "https://evlek.app/mcp",
      "protocolVersion": "2025-11-25",
      "categories": [
        "real-estate",
        "property",
        "data",
        "search"
      ],
      "tags": [
        "north-cyprus",
        "kktc",
        "trnc",
        "cyprus",
        "mediterranean",
        "property",
        "real-estate",
        "rental",
        "investment",
        "ai-native"
      ],
      "capabilities": {
        "tools": {
          "listChanged": false
        },
        "resources": {
          "listChanged": false
        },
        "prompts": {
          "listChanged": false
        }
      },
      "auth": {
        "required": false,
        "type": "none"
      },
      "rateLimits": {
        "perIp": "60/min",
        "global": "500/min",
        "batchSize": 20
      },
      "mobileApps": {
        "ios": "https://apps.apple.com/app/id6760562764",
        "android": "https://play.google.com/store/apps/details?id=app.evlek.mobile"
      },
      "tools": [
        {
          "name": "search_listings",
          "title": "Search Northern Cyprus Property Listings"
        },
        {
          "name": "get_price_index",
          "title": "Get Northern Cyprus Price Index"
        },
        {
          "name": "get_market_overview",
          "title": "Get Northern Cyprus Market Overview"
        },
        {
          "name": "compare_cities",
          "title": "Compare Northern Cyprus Cities Side-by-Side"
        },
        {
          "name": "get_yield_estimate",
          "title": "Estimate Rental Yield for a Northern Cyprus Property"
        },
        {
          "name": "get_legal_info",
          "title": "Get KKTC Property Legal Information"
        },
        {
          "name": "suggest_neighborhood",
          "title": "Suggest Best Northern Cyprus Neighborhoods for a Buyer Persona"
        },
        {
          "name": "compare_properties",
          "title": "Compare Evlek Property Listings Side-by-Side"
        },
        {
          "name": "get_district_profile",
          "title": "Get 360° Profile for a Northern Cyprus District"
        },
        {
          "name": "assess_title_risk",
          "title": "Assess KKTC Title-Deed (Koçan) Risk Band"
        },
        {
          "name": "foreign_buyer_roadmap",
          "title": "KKTC Foreign-Buyer Purchase Roadmap"
        },
        {
          "name": "student_housing",
          "title": "Student-Housing Rental Outlook near a KKTC University"
        },
        {
          "name": "payment_plan",
          "title": "KKTC Property Payment & Currency Breakdown"
        },
        {
          "name": "get_listing_detail",
          "title": "Get Full Detail for a Single Evlek Listing"
        },
        {
          "name": "search",
          "title": "Search Evlek property listings"
        },
        {
          "name": "fetch",
          "title": "Fetch full Evlek listing detail"
        }
      ],
      "resourceTemplates": [
        {
          "uriTemplate": "evlek://price-index/{city}",
          "name": "price-index"
        },
        {
          "uriTemplate": "evlek://district/{city}/{district}",
          "name": "district-profile"
        }
      ],
      "regions": [
        "TRNC",
        "Northern Cyprus",
        "Mediterranean"
      ],
      "languages": [
        "en",
        "tr",
        "ru",
        "de",
        "ar"
      ],
      "currencies": [
        "GBP",
        "TRY",
        "USD",
        "EUR"
      ]
    }
  }
}
